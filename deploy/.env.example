# ============================================
# 银行监管报送智能开发平台 - NAS 部署环境变量
# 本文件为模板，复制为 .env 后按实际环境修改
# ============================================

# 应用配置
APP_NAME=regulation-report-platform
APP_VERSION=2.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8080

# 数据库配置(平台配置库，SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/platform.db

# Redis配置(可选，NAS 部署默认不使用)
REDIS_URL=
USE_REDIS=false

# AI后端配置(主)
AI_BACKEND_PROVIDER=kimi
AI_BASE_URL=http://10.0.1.100:8000/v1
AI_API_KEY=
AI_MODEL=kimi-pro
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=8192
AI_TIMEOUT=60

# 离线Mock模式: true=内置 MockAIAdapter（Demo 默认，不依赖外部 AI Key）
AI_MOCK_MODE=true

# 向量库配置
VECTOR_STORE_TYPE=sqlite
VECTOR_DIMENSION=512
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_PROVIDER=local
EMBEDDING_REMOTE_BASE_URL=
EMBEDDING_REMOTE_API_KEY=
EMBEDDING_REMOTE_MODEL=
RETRIEVAL_VECTOR_WEIGHT=0.7
RETRIEVAL_TEXT_WEIGHT=0.3
RETRIEVAL_THRESHOLD=0.15

# 安全配置（⚠️ 生产部署必须修改 SECRET_KEY 为随机字符串）
SECRET_KEY=please-change-me-to-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS 允许源（NAS 访问时按需添加前端地址）
CORS_ORIGINS=http://localhost:5173,http://localhost:7100,http://127.0.0.1:5173,http://127.0.0.1:7100

# 文件上传
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./data/tenants

# MCP配置
MCP_DATABASE_READONLY=true
MCP_DATABASE_WHITELIST=loan_contract,customer_info,repay_plan,product_mapping
MCP_MAX_LIMIT=1000

# 演示数据集
DEMO_DB_PATH=./data/demo_biz.db

# 任务交付物工作目录
TASK_WORK_DIR=./data/tasks

# 任务 worker
TASK_WORKER_ENABLED=true
TASK_WORKER_MAX_CONCURRENCY=2
TASK_WORKER_POLL_INTERVAL=0.5
