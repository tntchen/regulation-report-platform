# ============================================
# 银行监管报送智能开发平台 - 环境变量配置
# 与 backend/config.py 的 Settings 字段逐项对应
# ============================================

# 应用配置
APP_NAME=regulation-report-platform
APP_VERSION=2.0.0
# 默认 false（生产姿态）；本地开发可置 true（允许 JWT 开发兜底密钥）
DEBUG=false
HOST=0.0.0.0
PORT=8080

# 数据库配置(平台配置库，SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/platform.db

# Redis配置(可选，默认不使用，使用内存缓存)
REDIS_URL=
USE_REDIS=false

# AI后端配置(主后端，OpenAI 兼容接口)
AI_BACKEND_PROVIDER=kimi
AI_BASE_URL=http://10.0.1.100:8000/v1
# 非 Mock 模式必填；缺失且 AI_MOCK_MODE=false 时 AI 调用 fail-fast 报错
AI_API_KEY=
AI_MODEL=kimi-pro
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=8192
AI_TIMEOUT=60

# 离线Mock模式: true=内置 MockAIAdapter（Demo 默认）；false 时必须配置 AI_API_KEY
AI_MOCK_MODE=true

# AI后端配置(备用，供租户 T002 的本地模型配置引用)
AI_BACKUP_PROVIDER=local
AI_BACKUP_BASE_URL=http://localhost:8000/v1
AI_BACKUP_API_KEY=
AI_BACKUP_MODEL=qwen-72b

# 向量库配置（当前实现：租户独立 SQLite 向量库 + BGE-small-zh 语义向量）
VECTOR_STORE_TYPE=sqlite
# 向量维度须与 embedding 模型一致：BGE-small-zh-v1.5 = 512
VECTOR_DIMENSION=512
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# Embedding 提供方: local=本地语义模型(默认) / remote=OpenAI兼容端点 / tfidf=无模型兜底
EMBEDDING_PROVIDER=local
# remote provider 配置（缺省时复用主 AI 后端配置）
EMBEDDING_REMOTE_BASE_URL=
EMBEDDING_REMOTE_API_KEY=
EMBEDDING_REMOTE_MODEL=
# 双通道融合检索权重与阈值
RETRIEVAL_VECTOR_WEIGHT=0.7
RETRIEVAL_TEXT_WEIGHT=0.3
RETRIEVAL_THRESHOLD=0.15

# 安全配置
# JWT 密钥：非 debug 模式必须注入真实随机密钥（缺失时启动报错）
SECRET_KEY=please-change-me-to-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS 允许源（逗号分隔；禁止 "*" + credentials 组合）
CORS_ORIGINS=http://localhost:5173,http://localhost:7100,http://127.0.0.1:5173,http://127.0.0.1:7100

# 文件上传
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./data/tenants

# MCP配置（只读纵深：sqlglot 强制只读 + 表白名单 + 行数上限）
MCP_DATABASE_READONLY=true
MCP_DATABASE_WHITELIST=loan_contract,customer_info,repay_plan,product_mapping
MCP_MAX_LIMIT=1000

# 演示数据集(SQLite种子库，供Agent 4/5离线验证)
DEMO_DB_PATH=./data/demo_biz.db

# 任务交付物工作目录
TASK_WORK_DIR=./data/tasks

# 任务 worker（异步执行引擎）
TASK_WORKER_ENABLED=true
TASK_WORKER_MAX_CONCURRENCY=2
TASK_WORKER_POLL_INTERVAL=0.5
