# ============================================
# 银行监管报送智能开发平台 - 环境变量配置
# ============================================

# 应用配置
APP_NAME=regulation-report-platform
APP_VERSION=2.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8080

# 数据库配置(平台配置库，SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/platform.db

# Redis配置(可选，没有则使用内存缓存)
REDIS_URL=redis://localhost:6379/0
USE_REDIS=false

# AI后端配置(主后端)
AI_BACKEND_PROVIDER=kimi
AI_BASE_URL=http://10.0.1.100:8000/v1
AI_API_KEY=your-kimi-api-key
AI_MODEL=kimi-pro
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=8192
AI_TIMEOUT=60

# AI后端配置(备用)
AI_BACKUP_PROVIDER=local
AI_BACKUP_BASE_URL=http://localhost:8000/v1
AI_BACKUP_API_KEY=not-needed
AI_BACKUP_MODEL=qwen-72b

# 向量库配置
VECTOR_STORE_TYPE=faiss
VECTOR_DIMENSION=768
EMBEDDING_MODEL=text2vec-large-chinese

# 租户默认配置
DEFAULT_TENANT_ID=T001
DEFAULT_TENANT_NAME=零售信贷中心

# 安全配置
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 文件上传
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./data/tenants

# MCP配置
MCP_DATABASE_READONLY=true
MCP_DATABASE_WHITELIST=loan_contract,customer_info,repay_plan,product_mapping
MCP_MAX_LIMIT=1000
